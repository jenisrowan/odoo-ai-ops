# Copy to .env for local development. In production these are injected by the
# ECS task definition (plain values) and AWS Secrets Manager (secrets).

LOG_LEVEL=INFO
ENABLE_SQS_WORKER=true

# AWS / SQS
AWS_REGION=ap-south-1
SQS_QUEUE_URL=

# Odoo (JSON-RPC + webhook forwarding)
ODOO_BASE_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_USERNAME=agent
ODOO_PASSWORD=change-me
AI_OPS_SHARED_TOKEN=change-me

# Anthropic
ANTHROPIC_API_KEY=
MODEL_MEDIUM=claude-haiku-4-5-20251001
MODEL_HIGH=claude-sonnet-5

# Valkey / Redis (LangGraph checkpoints)
VALKEY_URL=redis://localhost:6379

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL=#fraud-review

# Langfuse (self-hosted)
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
