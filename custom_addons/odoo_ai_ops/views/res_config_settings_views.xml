<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_ai_ops" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.ai.ops</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="AI Ops" string="AI Ops" name="odoo_ai_ops"
                     logo="/odoo_ai_ops/static/description/icon.png">
                    <block title="Fraud Gatekeeper" name="ai_ops_gatekeeper">
                        <setting string="Cheap-Order Auto-Rejection"
                                 help="Cancel cheap, risky orders directly in Shopify without spending LLM tokens.">
                            <field name="ai_ops_auto_reject_enabled"/>
                            <div class="content-group mt16"
                                 invisible="not ai_ops_auto_reject_enabled">
                                <div class="row">
                                    <label for="ai_ops_bypass_threshold" string="Reject orders under"
                                           class="col-lg-4 o_light_label"/>
                                    <field name="ai_ops_bypass_threshold"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                    <block title="Agent Cluster" name="ai_ops_agent">
                        <setting string="FastAPI Agent"
                                 help="Endpoint of the LangGraph agent cluster. The shared auth token is a secret, injected from AWS Secrets Manager as AI_OPS_SHARED_TOKEN (the agent reads the same value); it is not entered here.">
                            <div class="content-group">
                                <div class="row">
                                    <label for="ai_ops_agent_base_url" class="col-lg-4 o_light_label"/>
                                    <field name="ai_ops_agent_base_url"
                                           placeholder="http://fastapi.odoo.local:8000"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                    <block title="Shopify" name="ai_ops_shopify">
                        <setting string="Refund on Cancellation"
                                 help="Also refund the payment when AI Ops cancels an order in Shopify. Off by default: fraud rejections usually should not auto-refund.">
                            <field name="ai_ops_refund_on_cancel"/>
                        </setting>
                        <setting string="Shopify Admin API"
                                 help="Used to cancel/reject orders and register webhooks. The Admin API token is a secret: it is injected from AWS Secrets Manager as SHOPIFY_ADMIN_TOKEN and is not entered here.">
                            <div class="content-group">
                                <div class="row">
                                    <label for="ai_ops_shopify_shop_domain" class="col-lg-4 o_light_label"/>
                                    <field name="ai_ops_shopify_shop_domain"
                                           placeholder="my-store.myshopify.com"/>
                                </div>
                                <div class="row">
                                    <label for="ai_ops_shopify_api_version" class="col-lg-4 o_light_label"/>
                                    <field name="ai_ops_shopify_api_version"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Webhook Registration"
                                 help="Subscribe orders/create and orders/risk_assessment_changed to the edge ingress via the Admin API. Shopify's UI can't create HTTPS webhooks for a custom app. Idempotent - safe to re-run.">
                            <div class="content-group">
                                <div class="row">
                                    <label for="ai_ops_shopify_webhook_callback_url" class="col-lg-4 o_light_label"/>
                                    <field name="ai_ops_shopify_webhook_callback_url"
                                           placeholder="https://&lt;cloudfront-domain&gt;/webhooks/shopify"/>
                                </div>
                                <div class="mt8">
                                    <button type="object"
                                            name="action_ai_ops_register_shopify_webhooks"
                                            string="Register Shopify Webhooks"
                                            icon="fa-cloud-upload"
                                            class="btn-secondary"/>
                                </div>
                                <div class="text-muted mt4">
                                    Signature check uses the app's API secret; keep
                                    <strong>SHOPIFY_WEBHOOK_SECRET</strong> in sync with it.
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_ai_ops_config_settings" model="ir.actions.act_window">
        <field name="name">AI Ops Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="context">{'module': 'odoo_ai_ops', 'bin_size': False}</field>
    </record>
</odoo>
